#!/bin/bash
THISDIR="$( cd -P "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"
BASEDIR="$(dirname "$THISDIR")"
. "$dot_env_path/global/global_colors.sh"
. "$dot_env_path/global/global_functions.sh"

CONF_FILE="$HOME/.bash.env.conf"

ARGS=1

cmd="$1"
if [ $# -lt "$ARGS" ]; then
  cmd="help"
fi

# --- Helper functions ---

_conf_read_plugins() {
  if [[ -r "$CONF_FILE" ]]; then
    grep -E '^plugins=' "$CONF_FILE" | tail -1 | sed 's/^plugins=//' | tr -d '"' | tr -d "'"
  else
    echo "${plugins:-}"
  fi
}

_conf_read_theme() {
  if [[ -r "$CONF_FILE" ]]; then
    grep -E '^theme=' "$CONF_FILE" | tail -1 | sed 's/^theme=//' | tr -d '"' | tr -d "'"
  else
    echo "${theme:-}"
  fi
}

_conf_write() {
  local current_plugins="$1"
  local current_theme="$2"
  cat > "$CONF_FILE" <<EOF
# bash.env managed configuration
# Edit with: bash.env enable/disable <plugin> or bash.env set_theme <theme>
plugins="$current_plugins"
theme="$current_theme"
EOF
}

_conf_init() {
  if [[ ! -f "$CONF_FILE" ]]; then
    _conf_write "${plugins:-}" "${theme:-}"
    echo_info "Created $CONF_FILE"
  fi
}

_available_plugins() {
  for dir in "$BASEDIR"/plugins/*/; do
    local name
    name=$(basename "$dir")
    if [[ -f "$dir/${name}.plugin.sh" ]]; then
      echo "$name"
    fi
  done
}

_available_themes() {
  for dir in "$BASEDIR"/themes/*/; do
    local name
    name=$(basename "$dir")
    if [[ -f "$dir/theme.sh" ]]; then
      echo "$name"
    fi
  done
}

_is_plugin_enabled() {
  local plugin="$1"
  local enabled
  enabled=$(_conf_read_plugins)
  [[ " $enabled " == *" $plugin "* ]]
}

# --- Commands ---

function help() # Show this list of commands
{
  echo -e "${INFO}"
  grep "^function [a-z]" "$0" | sed 's/function /  bash.env /' | sed 's/() /\t/' | column -t -s '#'
  echo -e "${NORMAL}"
}

function add_bash_env_to() # Propagate your entire environment system to a remote host
{
  propagate_env_to_host "$@"
}

function add_ssh_key_to() # Add your public SSH key to a remote host
{
  add_ssh_key_to_host "$@"
}

function check_path_dups() # Show duplicate entries in your PATH
{
  echo -e "${INFO}"
  "$THISDIR/check_path_dups.rb"
  echo -e "${NORMAL}"
}

function colortest() # Show 256 color examples in your terminal
{
  "$THISDIR/colortest.sh"
}

function config() # Configure Bash.env for this host
{
  configthis.env
}

function config_host() # Configure Bash.env for a specified remote host
{
  confighost.env "$@"
}

function load_bash_env_on_alias() # Setup Bash.env to load using an alias
{
  load_on_alias
}

function load_bash_env_on_login() # Make Bash.env load on every login
{
  load_on_login
}

function update() # Update Bash.env to the latest version
{
  "$THISDIR/upgrade.env"
}

function vars() # Print sorted list of current shell environment variables
{
  echo -e "${INFO}"
  printenv | sort
  echo -e "${NORMAL}"
}

function enable() # Enable a plugin: bash.env enable <plugin>
{
  if [[ $# -lt 1 ]]; then
    echo_warn "Usage: bash.env enable <plugin>"
    return 1
  fi
  local plugin="$1"
  local plugin_path="$BASEDIR/plugins/$plugin/${plugin}.plugin.sh"

  if [[ ! -f "$plugin_path" ]]; then
    echo_error "Plugin not found: $plugin"
    echo_info "Available plugins:"
    _available_plugins | sed 's/^/  /'
    return 1
  fi

  _conf_init
  local current_plugins
  current_plugins=$(_conf_read_plugins)

  if [[ " $current_plugins " == *" $plugin "* ]]; then
    echo_warn "Plugin '$plugin' is already enabled"
    return 0
  fi

  if [[ -z "$current_plugins" ]]; then
    current_plugins="$plugin"
  else
    current_plugins="$current_plugins $plugin"
  fi

  _conf_write "$current_plugins" "$(_conf_read_theme)"
  echo_info "Enabled plugin: $plugin"
  echo_warn "Reload your shell to apply changes (bash.env reload)"
}

function disable() # Disable a plugin: bash.env disable <plugin>
{
  if [[ $# -lt 1 ]]; then
    echo_warn "Usage: bash.env disable <plugin>"
    return 1
  fi
  local plugin="$1"

  _conf_init
  local current_plugins
  current_plugins=$(_conf_read_plugins)

  if [[ " $current_plugins " != *" $plugin "* ]]; then
    echo_warn "Plugin '$plugin' is not enabled"
    return 0
  fi

  # Remove the plugin from the list
  current_plugins=$(echo "$current_plugins" | sed "s/\b${plugin}\b//" | tr -s ' ' | sed 's/^ *//;s/ *$//')

  _conf_write "$current_plugins" "$(_conf_read_theme)"
  echo_info "Disabled plugin: $plugin"
  echo_warn "Reload your shell to apply changes (bash.env reload)"
}

function search() # Search plugins and themes: bash.env search [term]
{
  local term="${1:-}"

  echo -e "${INFO}=== Plugins ===${NORMAL}"
  for plugin in $(_available_plugins); do
    if [[ -n "$term" && "$plugin" != *"$term"* ]]; then
      continue
    fi
    if _is_plugin_enabled "$plugin"; then
      echo -e "  ${LIGHT_GREEN}[enabled]${NORMAL}  $plugin"
    else
      echo -e "  ${DARK_GRAY}[disabled]${NORMAL} $plugin"
    fi
  done

  echo ""
  echo -e "${INFO}=== Themes ===${NORMAL}"
  local current_theme
  current_theme=$(_conf_read_theme)
  [[ -z "$current_theme" ]] && current_theme="${theme:-}"
  for t in $(_available_themes); do
    if [[ -n "$term" && "$t" != *"$term"* ]]; then
      continue
    fi
    if [[ "$t" == "$current_theme" ]]; then
      echo -e "  ${LIGHT_GREEN}[active]${NORMAL}   $t"
    else
      echo -e "  ${DARK_GRAY}[inactive]${NORMAL} $t"
    fi
  done
}

function preview() # Preview themes: bash.env preview [theme_name]
{
  local preview_theme="${1:-}"
  local themes_dir="$BASEDIR/themes"

  if [[ -n "$preview_theme" ]]; then
    local theme_file="$themes_dir/$preview_theme/theme.sh"
    if [[ ! -f "$theme_file" ]]; then
      echo_error "Theme not found: $preview_theme"
      return 1
    fi
    echo_info "Preview of theme: $preview_theme"
    echo "---"
    _preview_render_theme "$preview_theme"
    echo "---"
    echo_info "Try it: try_theme $preview_theme"
    echo_info "Reset:  reset_theme"
    return
  fi

  # Preview all themes
  echo_info "Available themes:"
  echo ""
  for dir in "$themes_dir"/*/; do
    local name
    name=$(basename "$dir")
    [[ ! -f "$dir/theme.sh" ]] && continue
    echo -e "${LIGHT_CYAN}$name${NORMAL}"
    _preview_render_theme "$name"
    echo ""
  done
  echo_info "Try a theme: try_theme <name>"
  echo_info "Reset theme: reset_theme"
}

_preview_render_theme() {
  local theme_name="$1"
  # Render the theme's PS1 with simulated real-world values in a subshell
  (
    theme="$theme_name"

    # Stub out helper functions with realistic sample data
    ps1_git_branch() { printf "main"; }
    ps1_git_status() { printf "*"; }
    ps1_sha() { printf "a3f7c2d"; }
    ps1_ruby() { printf "3.3.0"; }
    ps1_command_duration() { printf "12s"; }
    ps1_prompt_char() { printf '\$'; }
    ps1_system_ruby() { printf "∫3.3.0"; }

    # Stubs for kitchen_sink helpers
    __ks_ps1_node() { printf "20.11.0"; }
    __ks_ps1_venv() { printf ""; }
    __ks_ps1_exit_code() { printf ""; }
    __ks_ps1_jobs() { printf ""; }

    source "$BASEDIR/themes/load_theme.sh"

    # Replace prompt escapes with simulated values
    local rendered="$PS1"

    # Strip \[ and \] (prompt non-printing markers)
    rendered="${rendered//\\[/}"
    rendered="${rendered//\\]/}"

    # Replace bash prompt escapes with sample data
    rendered="${rendered//\\u/midwire}"
    rendered="${rendered//\\H/myhost.local}"
    rendered="${rendered//\\h/myhost}"
    rendered="${rendered//\\w/~/projects/myapp}"
    rendered="${rendered//\\W/myapp}"

    # Expand command substitutions and remaining escapes
    echo -e "  $(eval echo -e "\"$rendered\"")"
  ) 2>/dev/null
}

function doctor() # Diagnostics: show system info and potential issues
{
  echo -e "${INFO}=== bash.env Doctor ===${NORMAL}"
  echo ""

  # Version
  local version
  version=$(cat "$BASEDIR/VERSION" 2>/dev/null || echo "unknown")
  echo -e "  ${LIGHT_CYAN}Version:${NORMAL}      $version"

  # OS
  echo -e "  ${LIGHT_CYAN}OS:${NORMAL}           $(uname -s) $(uname -r)"

  # Bash version
  echo -e "  ${LIGHT_CYAN}Bash:${NORMAL}         $BASH_VERSION"

  # Terminal
  echo -e "  ${LIGHT_CYAN}Terminal:${NORMAL}     ${TERM:-unknown}"

  # Installation path
  echo -e "  ${LIGHT_CYAN}Install path:${NORMAL} $BASEDIR"

  # Custom directory
  local custom_dir="${dot_env_custom:-$BASEDIR/custom}"
  if [[ -d "$custom_dir" ]]; then
    echo -e "  ${LIGHT_CYAN}Custom dir:${NORMAL}   $custom_dir ${LIGHT_GREEN}(exists)${NORMAL}"
  else
    echo -e "  ${LIGHT_CYAN}Custom dir:${NORMAL}   $custom_dir ${DARK_GRAY}(not found)${NORMAL}"
  fi

  # Config file
  if [[ -f "$CONF_FILE" ]]; then
    echo -e "  ${LIGHT_CYAN}Config file:${NORMAL}  $CONF_FILE ${LIGHT_GREEN}(exists)${NORMAL}"
  else
    echo -e "  ${LIGHT_CYAN}Config file:${NORMAL}  $CONF_FILE ${DARK_GRAY}(not created)${NORMAL}"
  fi

  echo ""

  # Current theme
  local current_theme
  current_theme=$(_conf_read_theme)
  [[ -z "$current_theme" ]] && current_theme="${theme:-default}"
  echo -e "  ${LIGHT_CYAN}Theme:${NORMAL}        $current_theme"

  # Enabled plugins
  local enabled_plugins
  enabled_plugins=$(_conf_read_plugins)
  [[ -z "$enabled_plugins" ]] && enabled_plugins="${plugins:-}"
  echo -e "  ${LIGHT_CYAN}Plugins:${NORMAL}      ${enabled_plugins:-none}"

  echo ""

  # Checks
  echo -e "${INFO}=== Health Checks ===${NORMAL}"

  # PATH duplicates
  local dup_count
  dup_count=$(echo "$PATH" | tr ':' '\n' | sort | uniq -d | wc -l)
  if [[ "$dup_count" -gt 0 ]]; then
    echo -e "  ${YELLOW}[WARN]${NORMAL} PATH has $dup_count duplicate entries (run: bash.env check_path_dups)"
  else
    echo -e "  ${LIGHT_GREEN}[OK]${NORMAL}   PATH has no duplicate entries"
  fi

  # Check that theme file exists
  local theme_file="$BASEDIR/themes/${current_theme}/theme.sh"
  if [[ -f "$theme_file" ]]; then
    echo -e "  ${LIGHT_GREEN}[OK]${NORMAL}   Theme file exists: $theme_file"
  else
    echo -e "  ${LIGHT_RED}[ERR]${NORMAL}  Theme file missing: $theme_file"
  fi

  # Check for host directory
  if [[ -n "$HOSTNAME" && -d "$BASEDIR/host/$HOSTNAME" ]]; then
    echo -e "  ${LIGHT_GREEN}[OK]${NORMAL}   Host config exists: $BASEDIR/host/$HOSTNAME"
  elif [[ -n "$HOSTNAME" ]]; then
    echo -e "  ${DARK_GRAY}[INFO]${NORMAL} No host config for $HOSTNAME (run: bash.env config)"
  fi

  # Check for stale plugins (enabled but missing)
  if [[ -n "$enabled_plugins" ]]; then
    for plugin in $enabled_plugins; do
      local plugin_path="$BASEDIR/plugins/$plugin/${plugin}.plugin.sh"
      local custom_path="${custom_dir}/plugins/$plugin/${plugin}.plugin.sh"
      if [[ ! -f "$plugin_path" && ! -f "$custom_path" ]]; then
        echo -e "  ${LIGHT_RED}[ERR]${NORMAL}  Enabled plugin missing: $plugin"
      fi
    done
  fi

  echo ""
}

function set_theme() # Set the active theme: bash.env set_theme <theme>
{
  if [[ $# -lt 1 ]]; then
    echo_warn "Usage: bash.env set_theme <theme>"
    return 1
  fi
  local new_theme="$1"
  local theme_file="$BASEDIR/themes/$new_theme/theme.sh"

  if [[ ! -f "$theme_file" ]]; then
    echo_error "Theme not found: $new_theme"
    echo_info "Available themes:"
    _available_themes | sed 's/^/  /'
    return 1
  fi

  _conf_init
  _conf_write "$(_conf_read_plugins)" "$new_theme"
  echo_info "Theme set to: $new_theme"
  echo_warn "Reload your shell to apply changes (bash.env reload)"
}

function profile() # Manage profiles: bash.env profile save|load|list [name]
{
  local profiles_dir="$BASEDIR/profiles"
  mkdir -p "$profiles_dir"

  local action="${1:-list}"
  local name="${2:-}"

  case "$action" in
    save)
      if [[ -z "$name" ]]; then
        echo_warn "Usage: bash.env profile save <name>"
        return 1
      fi
      _conf_init
      cp "$CONF_FILE" "$profiles_dir/${name}.conf"
      echo_info "Profile saved: $name"
      ;;
    load)
      if [[ -z "$name" ]]; then
        echo_warn "Usage: bash.env profile load <name>"
        return 1
      fi
      local profile_file="$profiles_dir/${name}.conf"
      if [[ ! -f "$profile_file" ]]; then
        echo_error "Profile not found: $name"
        echo_info "Available profiles:"
        profile list
        return 1
      fi
      cp "$profile_file" "$CONF_FILE"
      echo_info "Loaded profile: $name"
      echo_warn "Reload your shell to apply changes (bash.env reload)"
      ;;
    list)
      echo_info "Saved profiles:"
      local found=0
      for f in "$profiles_dir"/*.conf; do
        [[ ! -f "$f" ]] && continue
        found=1
        local pname
        pname=$(basename "$f" .conf)
        echo "  $pname"
      done
      if [[ "$found" -eq 0 ]]; then
        echo "  (none)"
      fi
      ;;
    delete)
      if [[ -z "$name" ]]; then
        echo_warn "Usage: bash.env profile delete <name>"
        return 1
      fi
      local profile_file="$profiles_dir/${name}.conf"
      if [[ ! -f "$profile_file" ]]; then
        echo_error "Profile not found: $name"
        return 1
      fi
      rm "$profile_file"
      echo_info "Deleted profile: $name"
      ;;
    *)
      echo_warn "Usage: bash.env profile save|load|list|delete [name]"
      return 1
      ;;
  esac
}

function reload() # Reload the bash.env environment
{
  if [[ -r "$HOME/.bashrc" ]]; then
    echo_info "Reloading environment..."
    source "$HOME/.bashrc"
  elif [[ -r "$HOME/.env/bash.env.sh" ]]; then
    source "$HOME/.env/bash.env.sh"
  else
    echo_error "Cannot find .bashrc or bash.env.sh to reload"
    return 1
  fi
}

# Execute the requested function, or help()
if [ "_$1" = "_" ]; then
  help
else
  "$@"
fi
